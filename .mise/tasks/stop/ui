#!/usr/bin/env bash
#MISE description="Stop only admin UI (leave svoted + nf-server running)"
#MISE quiet=true

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_FILE="$DIR/.pids/ui.pid"
UI_PORT="${SVOTE_UI_PORT:-5173}"

PID=""
PID="$(lsof -tnP -iTCP:$UI_PORT -sTCP:LISTEN 2>/dev/null | head -1 || true)"
if [ -z "$PID" ] && [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    PID="$(cat "$PID_FILE")"
fi

if [ -n "$PID" ]; then
    kill "$PID" 2>/dev/null || true
    for i in $(seq 1 20); do
        kill -0 "$PID" 2>/dev/null || break
        sleep 0.25
    done
    rm -f "$PID_FILE"
    printf '\033[32mStopped admin UI\033[0m\n'
else
    rm -f "$PID_FILE"
    echo "admin UI is not running."
fi
