#!/usr/bin/env bash
#MISE description="Stop only nf-server (leave svoted + admin UI running)"
#MISE quiet=true

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_FILE="$DIR/.pids/nf.pid"
PORT=3000

# Find whatever is actually bound to the port — survives stale PID files.
LISTENING_PID=$(lsof -tnP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | head -1 || true)

if [ -n "$LISTENING_PID" ]; then
    kill "$LISTENING_PID" 2>/dev/null || true
    rm -f "$PID_FILE"
    printf '\033[32mStopped nf-server (pid %s)\033[0m\n' "$LISTENING_PID"
else
    rm -f "$PID_FILE"
    echo "nf-server is not running."
fi
