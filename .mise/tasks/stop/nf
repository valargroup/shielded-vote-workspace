#!/usr/bin/env bash
#MISE description="Stop only nf-server (leave svoted running)"
#MISE quiet=true

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_FILE="$DIR/.pids/nf.pid"
PORT="${SVOTE_PIR_PORT:-${PORT:-3000}}"

# Find whatever is actually bound to the port — survives stale PID files.
LISTENING_PID=$(lsof -tnP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | head -1 || true)

if [ -n "$LISTENING_PID" ]; then
    if ! kill "$LISTENING_PID" 2>/dev/null; then
        printf '\033[31mFailed to stop nf-server (pid %s) on port %s.\033[0m\n' "$LISTENING_PID" "$PORT"
        printf 'Try from your shell: kill %s\n' "$LISTENING_PID"
        exit 1
    fi

    for _ in $(seq 1 10); do
        if ! lsof -tnP -iTCP:$PORT -sTCP:LISTEN >/dev/null 2>&1; then
            rm -f "$PID_FILE"
            printf '\033[32mStopped nf-server (pid %s)\033[0m\n' "$LISTENING_PID"
            exit 0
        fi
        sleep 0.2
    done

    printf '\033[31mSent SIGTERM to nf-server (pid %s), but port %s is still listening.\033[0m\n' "$LISTENING_PID" "$PORT"
    exit 1
else
    rm -f "$PID_FILE"
    echo "nf-server is not running."
fi
