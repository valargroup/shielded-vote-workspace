#!/usr/bin/env bash
#MISE description="Stop all services"
#MISE alias="stop"
#MISE quiet=true

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_DIR="$DIR/.pids"

KILLED=""
for svc in chain nf ui; do
    PID_FILE="$PID_DIR/$svc.pid"
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        kill "$(cat "$PID_FILE")" 2>/dev/null
        KILLED="$KILLED $svc"
    fi
    rm -f "$PID_FILE"
done

if [ -n "$KILLED" ]; then
    printf '\033[32mStopped:%s\033[0m\n' "$KILLED"
else
    echo "No running processes found."
fi
rm -f "$DIR/zodl-ios/secant/Resources/voting-config-local.json"
