#!/usr/bin/env bash
#MISE description="Stop only svoted (leave nf-server + admin UI running)"
#MISE quiet=true

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_FILE="$DIR/.pids/chain.pid"

if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    kill "$(cat "$PID_FILE")" 2>/dev/null
    for i in $(seq 1 20); do
        kill -0 "$(cat "$PID_FILE")" 2>/dev/null || break
        sleep 0.25
    done
    rm -f "$PID_FILE"
    printf '\033[32mStopped svoted\033[0m\n'
else
    rm -f "$PID_FILE"
    echo "svoted is not running."
fi
