#!/usr/bin/env bash
#MISE description="Stop only svoted (leave nf-server + admin UI running)"
#MISE quiet=true

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_FILE="$DIR/.pids/chain.pid"
CHAIN_PORT="${SVOTE_CHAIN_PORT:-1317}"

PID=""
if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    PID="$(cat "$PID_FILE")"
else
    PID="$(lsof -tnP -iTCP:$CHAIN_PORT -sTCP:LISTEN 2>/dev/null | head -1 || true)"
fi

if [ -n "$PID" ]; then
    kill "$PID" 2>/dev/null || true
    for i in $(seq 1 20); do
        kill -0 "$PID" 2>/dev/null || break
        sleep 0.25
    done
    rm -f "$PID_FILE"
    printf '\033[32mStopped svoted\033[0m\n'
else
    rm -f "$PID_FILE"
    echo "svoted is not running."
fi
